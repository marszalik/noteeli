NOTEELI_CONTENT_ROOT=/Users/twoj-user/notatki
NOTEELI_DATA_DIR=/Users/twoj-user/.noteeli
NOTEELI_SESSION_SECRET=zmien-ten-sekret-przed-wdrozeniem

# Google OAuth
NOTEELI_GOOGLE_CLIENT_ID=
NOTEELI_GOOGLE_CLIENT_SECRET=
# Comma-separated list of Google emails allowed to log in (leave empty = allow all)
NOTEELI_ALLOWED_GOOGLE_EMAILS=jane.doe@example.com,john.doe@example.com

# Built-in password login (leave both empty to disable this login method)
NOTEELI_LOCAL_USERNAME=admin
NOTEELI_LOCAL_PASSWORD=changeme
